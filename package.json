{
  "name": "ai-linkedin-job-automation",
  "version": "1.0.0",
  "private": true,
  "description": "AI-powered LinkedIn job application automation system",
  "scripts": {
    "backend:install": "cd backend && npm install",
    "frontend:install": "cd frontend && npm install",
    "backend:dev": "cd backend && npm run dev",
    "frontend:dev": "cd frontend && npm run dev",
    "backend:build": "cd backend && npm run build",
    "frontend:build": "cd frontend && npm run build",
    "backend:start": "cd backend && npm start",
    "frontend:start": "cd frontend && npm start",
    "dev": "concurrently -k -n BACKEND,FRONTEND -c blue,green \"npm run backend:dev\" \"npm run frontend:dev\"",
    "build": "npm run backend:build && npm run frontend:build",
    "start": "concurrently -k -n BACKEND,FRONTEND -c blue,green \"npm run backend:start\" \"npm run frontend:start\"",
    "setup": "npm install && npm run backend:install && npm run frontend:install",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "test": "jest --passWithNoTests",
    "clean": "rm -rf node_modules backend/node_modules frontend/node_modules",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  },
  "keywords": [
    "linkedin",
    "automation",
    "job",
    "application",
    "ai",
    "playwright",
    "nextjs",
    "mongodb"
  ],
  "author": "JP IT Staffing",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "jest": "^29.7.0"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "playwright": "^1.60.0"
  }
}
