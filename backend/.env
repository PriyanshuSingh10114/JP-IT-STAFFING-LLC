# ============================================
# MongoDB Configuration
# ============================================
MONGODB_URI=mongodb://localhost:27017/job_automation_db
MONGODB_DB_NAME=job_automation_db

# ============================================
# Redis Configuration
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379

# ============================================
# Backend Server Configuration
# ============================================
BACKEND_PORT=5000
BACKEND_URL=http://localhost:5000
NODE_ENV=development

# ============================================
# Frontend Configuration
# ============================================
FRONTEND_PORT=3000
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# ============================================
# Gmail Configuration
# ============================================
GMAIL_CLIENT_ID=your_gmail_client_id_here
GMAIL_CLIENT_SECRET=your_gmail_client_secret_here
GMAIL_REFRESH_TOKEN=your_gmail_refresh_token_here
GMAIL_USER_EMAIL=your_gmail_address@gmail.com

# ============================================
# OpenAI Configuration
# ============================================
OPENAI_API_KEY=sk-your_openai_key_here
OPENAI_MODEL=gpt-4

# ============================================
# LinkedIn Configuration
# ============================================
LINKEDIN_EMAIL=your_linkedin_email@gmail.com
LINKEDIN_PASSWORD=your_linkedin_password
LINKEDIN_SESSION_PATH=./sessions/linkedin

# ============================================
# LinkedIn Automation Settings
# ============================================
LINKEDIN_SEARCH_KEYWORDS=Java Developer,Backend Engineer,Full Stack Developer
LINKEDIN_JOB_TYPE=Contract,Fulltime
LINKEDIN_LOCATION=United States,Remote
LINKEDIN_HEADLESS=true
LINKEDIN_PROXY=
LINKEDIN_TIMEOUT=30000

# ============================================
# Email Hunter API (Optional)
# ============================================
HUNTER_API_KEY=your_hunter_api_key_here

# ============================================
# Apollo API (Optional)
# ============================================
APOLLO_API_KEY=your_apollo_api_key_here

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=debug
LOG_FILE_PATH=./logs/app.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=14

# ============================================
# Scheduler Configuration
# ============================================
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_MINUTES=60
SCHEDULER_MAX_JOBS_PER_RUN=20

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# Automation Settings
# ============================================
AUTO_LOGIN_ENABLED=true
AUTO_RETRY_ATTEMPTS=3
AUTO_RETRY_DELAY_MS=5000
DUPLICATE_CHECK_ENABLED=true

# ============================================
# Security
# ============================================
JWT_SECRET=development_secret_key_123456789
ENCRYPTION_KEY=development_encryption_key_32_chars_long_123
